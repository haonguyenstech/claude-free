{
  "name": "claude-free",
  "version": "2.1.0",
  "private": true,
  "description": "claude-free — run Claude Code on free AI models. Single Next.js app: BE (Anthropic Messages API proxy + admin API) + FE (operator dashboard).",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start -H ${CLAUDE_FREE_HOST:-127.0.0.1} -p ${PORT:-4002}",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/lib/db/seed.ts"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-slot": "^1.1.2",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^0.468.0",
    "next": "^16.2.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.20.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.10",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "~5.7.2"
  }
}
