# claude-free — environment configuration template
# Copy to `.env` and fill in. `.env` is gitignored; this template is safe to commit.
# Next.js loads .env automatically on `npm run dev` / `npm start`.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
CLAUDE_FREE_HOST=0.0.0.0

# ── Data ───────────────────────────────────────────────────────────────────────
# Where the SQLite DB + legacy keys.json live. Defaults to the working directory.
# CLAUDE_FREE_HOME=
# CLAUDE_FREE_DB=

# ── Dashboard login (seeded into the DB on first run only) ──────────────────────
# Create the default admin account the FIRST time the users table is empty.
# IMPORTANT: changing these later does NOT update an account that already exists.
# To rotate an existing password, either start with a fresh DB, or clear the users
# table so it re-seeds:  sqlite3 claude-free.db "DELETE FROM users;"  then restart.
CLAUDE_FREE_ADMIN_EMAIL=admin@example.com
CLAUDE_FREE_ADMIN_PASSWORD=change-me

# Optional ops escape-hatch: admin password accepted via the x-admin-password header
# for the dashboard API, independent of the login session.
# CLAUDE_FREE_ADMIN=

# ── Proxy access tokens (gate /v1/messages) ─────────────────────────────────────
# Comma-separated API keys clients must present; merged with keys made in the UI.
# CLAUDE_FREE_TOKENS=

# Set to 1 to pause the proxy (rejects all model requests; dashboard stays up).
# CLAUDE_FREE_OFF=0

# Default output cap when a client omits max_tokens (Claude Code always sends its own,
# so this only affects raw/3rd-party clients). Lower it if an upstream rejects large values.
# CLAUDE_FREE_MAX_TOKENS=8192

# ── Backend credentials (override anything stored via the dashboard) ────────────
# TOKENROUTER_KEY=
# OPENROUTER_KEY=
# GEMINI_KEY=
# CLINEPASS_KEY=     # ClinePass API key from app.cline.bot
